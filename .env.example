# Copy to .env (local ingest) or .env.cloud (Qdrant Cloud trial).
# Do not commit .env / .env.cloud to git.

# --- Local ingest (việc 1) ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # not needed for local Qdrant
QDRANT_COLLECTION=legal_documents

# --- Qdrant Cloud trial (việc 2) — put in .env.cloud ---
# QDRANT_URL=https://YOUR-CLUSTER.us-west-1-0.aws.cloud.qdrant.io
# QDRANT_API_KEY=your-api-key
# QDRANT_COLLECTION=vld_business_law
# QDRANT_VECTOR_NAME=dense

# Optional: override embedding model path
# EMBED_MODEL_PATH=/path/to/Vietnamese_Embedding
